# Copie para .env e ajuste conforme seu ambiente
# cp .env.example .env

PORT=3000

# Origens permitidas — site + painel (subdomínio) + local
# Produção (sthevandev.com.br):
# CORS_ORIGIN=https://sthevandev.com.br,https://www.sthevandev.com.br,https://painel.sthevandev.com.br
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://sthevandev.com.br,https://www.sthevandev.com.br,https://painel.sthevandev.com.br

# Segredo do token do painel (troque em produção)
AUTH_SECRET=troque-este-segredo-em-producao

# MySQL Hostinger (dados do hPanel → Bancos de dados MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=barbearia

# Forçar armazenamento em arquivo JSON (útil para demo local)
# STORAGE=json

# --- Lembrete WhatsApp automático (Evolution API) ---
# LEMBRETE_HORAS_ANTES=2
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_INSTANCE=chatubas
# EVOLUTION_API_KEY=sua_chave
